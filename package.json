{
  "name": "pos-saas-management-system",
  "description": "POS SaaS Management System (Web + Desktop Electron)",
  "author": "PointPro POS",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "main": "dist-electron/electron/main.js",
  "scripts": {
    "dev": "node scripts/clean-next.cjs && next dev",
    "dev:desktop": "concurrently -k -n NEXT,ELECTRON -c blue,green \"next dev\" \"wait-on http://localhost:3000 && cross-env ELECTRON_RENDERER_URL=http://localhost:3000 npm run electron:build-and-run\"",
    "build": "npm run prisma:generate && next build",
    "start": "next start",
    "lint": "eslint . --ext .js,.jsx,.ts,.tsx",
    "typecheck": "tsc --noEmit",
    "prisma:generate": "prisma generate --schema src/prisma/schema.prisma",
    "prisma:migrate": "prisma migrate dev --schema src/prisma/schema.prisma",
    "prisma:deploy": "prisma migrate deploy --schema src/prisma/schema.prisma",
    "prisma:studio": "prisma studio --schema src/prisma/schema.prisma",
    "prisma:generate:mysql": "prisma generate --schema src/prisma/schema.mysql.prisma",
    "prisma:migrate:mysql": "prisma migrate dev --schema src/prisma/schema.mysql.prisma",
    "prisma:studio:mysql": "prisma studio --schema src/prisma/schema.mysql.prisma",
    "db:seed": "node scripts/seed.mjs",
    "db:seed:mysql": "node scripts/seed.mjs",
    "db:setup:neon": "npm run prisma:deploy && npm run db:seed",
    "electron:build": "tsc -p electron/tsconfig.json && node scripts/electron-postbuild.mjs",
    "electron:build-and-run": "npm run electron:build && node scripts/run-electron.cjs",
    "desktop:run": "node scripts/run-electron.cjs",
    "desktop:rebuild-native": "node scripts/rebuild-electron-native.cjs",
    "build:desktop:renderer": "set DESKTOP_BUILD=1&& node scripts/clean-next.cjs && npx next build && node scripts/build-desktop-renderer.mjs",
    "desktop:dist": "node scripts/desktop-dist.cjs",
    "desktop:build": "cross-env ELECTRON_RENDERER_URL=https://pos-next-js-kohl.vercel.app npm run build && npm run electron:build && node scripts/clean-desktop-build.cjs && electron-builder",
    "android:sync": "cap sync android",
    "android:open": "cap open android",
    "android:gradle:stop": "node scripts/run-android-gradle.cjs --stop",
    "android:keystore:generate": "node scripts/generate-android-keystore.cjs",
    "android:build:debug": "node scripts/run-android-gradle.cjs assembleDebug",
    "android:build:release": "node scripts/run-android-gradle.cjs assembleRelease",
    "android:copy-apk:debug": "node scripts/copy-android-apk.cjs",
    "android:copy-apk:release": "node scripts/copy-android-apk-release.cjs",
    "android:assets": "npx.cmd @capacitor/assets generate --android --iconBackgroundColor \"#0b3df0\" --iconBackgroundColorDark \"#0b1220\" --splashBackgroundColor \"#0b1220\" --splashBackgroundColorDark \"#0b1220\""
  },
  "dependencies": {
    "@auth/prisma-adapter": "^2.10.0",
    "@hookform/resolvers": "^5.4.0",
    "@prisma/client": "^6.8.2",
    "@radix-ui/react-avatar": "^1.1.10",
    "@radix-ui/react-dialog": "^1.1.15",
    "@radix-ui/react-dropdown-menu": "^2.1.15",
    "@radix-ui/react-label": "^2.1.8",
    "@radix-ui/react-separator": "^1.1.7",
    "@radix-ui/react-slot": "^1.2.3",
    "@radix-ui/react-tooltip": "^1.2.8",
    "@tanstack/react-table": "^8.21.3",
    "@types/qrcode": "^1.5.6",
    "@upstash/ratelimit": "^2.0.8",
    "@upstash/redis": "^1.38.0",
    "bcryptjs": "^3.0.2",
    "better-sqlite3": "^12.10.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "date-fns": "^4.3.0",
    "google-auth-library": "^10.6.2",
    "jspdf": "^2.5.1",
    "jspdf-autotable": "^3.8.4",
    "lucide-react": "^1.16.0",
    "next": "15.5.18",
    "next-auth": "^5.0.0-beta.28",
    "next-themes": "^0.4.6",
    "nodemailer": "^7.0.13",
    "qrcode": "^1.5.4",
    "react": "19.2.6",
    "react-dom": "19.2.6",
    "react-hook-form": "^7.62.0",
    "tailwind-merge": "^3.6.0",
    "tesseract.js": "^7.0.0",
    "xlsx": "^0.18.5",
    "zod": "^3.25.28"
  },
  "devDependencies": {
    "@capacitor/android": "^8.3.4",
    "@capacitor/assets": "^3.0.5",
    "@capacitor/cli": "^8.3.4",
    "@capacitor/core": "^8.3.4",
    "@types/bcryptjs": "^2.4.6",
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "22.19.17",
    "@types/nodemailer": "^6.4.17",
    "@types/react": "19.2.7",
    "@types/react-dom": "19.2.3",
    "astral-regex": "^2.0.0",
    "autoprefixer": "^10.4.21",
    "concurrently": "^9.2.0",
    "cross-env": "^7.0.3",
    "electron": "^32.2.0",
    "electron-builder": "^25.1.8",
    "electron-rebuild": "^3.2.9",
    "electron-updater": "^6.6.2",
    "eslint": "^8.57.0",
    "eslint-config-next": "^15.3.2",
    "postcss": "^8.5.3",
    "prisma": "^6.8.2",
    "tailwindcss": "^3.4.17",
    "typescript": "5.9.3",
    "typescript-eslint": "^8.33.0",
    "wait-on": "^7.2.0"
  },
  "build": {
    "appId": "com.pointpro.posdesktop",
    "productName": "POS Desktop Enterprise",
    "extraMetadata": {
      "desktopRendererUrl": "https://pos-next-js-kohl.vercel.app"
    },
    "directories": {
      "output": "dist-desktop-build"
    },
    "files": [
      "dist-electron/**",
      "package.json"
    ],
    "win": {
      "target": [
        "nsis",
        "portable"
      ]
    }
  }
}
