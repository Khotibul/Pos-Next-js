## Android release signing config (DO NOT COMMIT secrets)
#
# 1) Generate keystore:
# keytool -genkeypair -v -keystore pos-pro-release.keystore -alias pospro -keyalg RSA -keysize 2048 -validity 10000
#
# 2) Place keystore file:
# android/app/pos-pro-release.keystore
#
# 3) Copy this file to `android/keystore.properties` and fill values.
#
storeFile=app/pos-pro-release.keystore
storePassword=CHANGE_ME
keyAlias=pospro
keyPassword=CHANGE_ME

