generator client {
  provider = "prisma-client-js"
  engineType = "binary"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// Needed by Product prices
// See: https://www.prisma.io/docs/orm/reference/prisma-schema-reference#decimal

enum TenantStatus {
  ACTIVE
  TRIAL
  SUSPENDED
  EXPIRED
}

enum AnnouncementStatus {
  DRAFT
  PUBLISHED
  ARCHIVED
}

enum PurchaseStatus {
  DRAFT
  ORDERED
  RECEIVED
  CANCELED
}

enum ShiftStatus {
  OPEN
  CLOSED
  APPROVED
}

model Plan {
  id           String   @id @default(cuid())
  slug         String   @unique
  name         String
  description  String?
  priceMonthly Decimal  @default(0)
  currency     String   @default("IDR")
  trialDays    Int      @default(14)
  isPopular    Boolean  @default(false)
  isActive     Boolean  @default(true)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  tenants Tenant[]
  licenseKeys LicenseKey[]
}

model Tenant {
  id        String       @id @default(cuid())
  name      String
  slug      String       @unique
  domain    String?
  subdomain String?
  status    TenantStatus @default(TRIAL)
  trialEndsAt DateTime?
  planId    String?
  suspendedAt DateTime?
  createdAt DateTime     @default(now())
  updatedAt DateTime     @updatedAt

  plan      Plan?        @relation(fields: [planId], references: [id], onDelete: SetNull)
  licenseKeys LicenseKey[]
  memberships TenantUser[]
  roles       Role[]
  permissions Permission[]
  products    Product[]
  sales       Sale[]
  productCategories ProductCategory[]
  productBrands     ProductBrand[]
  productUnits      ProductUnit[]
  customers  Customer[]
  suppliers  Supplier[]
  settings   Setting[]
  auditLogs   AuditLog[]
  purchaseOrders PurchaseOrder[]
  cashierShifts  CashierShift[]
  branches   Branch[]
  branchCategories BranchCategory[]
  productImages ProductImage[]
  productVariants ProductVariant[]
  productUnitOptions ProductUnitOption[]
  productUnitConversions ProductUnitConversion[]
  warehouses Warehouse[]
  productBatches ProductBatch[]
  productWarehouseStocks ProductWarehouseStock[]
  productPrices ProductPrice[]
  productPriceHistory ProductPriceHistory[]
  productCostHistory ProductCostHistory[]
  productSerials ProductSerial[]
  productSuppliers ProductSupplier[]
  productBundles ProductBundle[]
  productBundleItems ProductBundleItem[]
  productAssemblies ProductAssembly[]
  productAssemblyItems ProductAssemblyItem[]
  productTransfers ProductTransfer[]
  productTransferItems ProductTransferItem[]
  productAdjustments ProductAdjustment[]
  productAdjustmentItems ProductAdjustmentItem[]
  productOpnames ProductOpname[]
  productOpnameItems ProductOpnameItem[]

  @@unique([domain])
  @@unique([subdomain])
  @@index([planId])
}

model LicenseKey {
  id        String   @id @default(cuid())
  serial    String   @unique
  planId    String?
  tenantId  String?  @unique
  expiresAt DateTime?
  revokedAt DateTime?
  redeemedAt DateTime?
  createdAt DateTime @default(now())

  plan   Plan?   @relation(fields: [planId], references: [id], onDelete: SetNull)
  tenant Tenant? @relation(fields: [tenantId], references: [id], onDelete: SetNull)

  @@index([planId])
  @@index([expiresAt])
}

model Setting {
  id        String   @id @default(cuid())
  tenantId  String
  key       String
  value     Json
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@unique([tenantId, key])
  @@index([tenantId])
}

model Announcement {
  id        String             @id @default(cuid())
  title     String
  message   String
  status    AnnouncementStatus @default(DRAFT)
  startsAt  DateTime?
  endsAt    DateTime?
  createdAt DateTime           @default(now())
  updatedAt DateTime           @updatedAt
}

model GlobalSetting {
  id        String   @id @default(cuid())
  key       String   @unique
  value     Json
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model User {
  id            String    @id @default(cuid())
  name          String?
  email         String?   @unique
  phone         String?
  emailVerified DateTime?
  image         String?
  passwordHash  String?
  isSuperAdmin  Boolean   @default(false)
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  accounts    Account[]
  sessions    Session[]
  memberships TenantUser[]
  auditLogs   AuditLog[]
  cashierShiftsAsCashier CashierShift[] @relation("CashierShiftCashier")
  cashierShiftsApproved  CashierShift[] @relation("CashierShiftApprovedBy")
  emailVerificationTokens EmailVerificationToken[]
  productPriceChanges ProductPriceHistory[] @relation("ProductPriceHistoryChangedBy")
  productCostChanges  ProductCostHistory[] @relation("ProductCostHistoryCreatedBy")
  productTransfers    ProductTransfer[] @relation("ProductTransferCreatedBy")
  productAdjustments  ProductAdjustment[] @relation("ProductAdjustmentCreatedBy")
  productOpnames      ProductOpname[] @relation("ProductOpnameCreatedBy")
}

model EmailVerificationToken {
  id        String   @id @default(cuid())
  userId    String
  email     String
  token     String   @unique
  expiresAt DateTime
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([email])
  @@index([expiresAt])
}

model OauthRegistration {
  id        String   @id @default(cuid())
  tenantName String
  ownerName  String
  phone      String?
  planSlug   String?
  createdAt DateTime @default(now())
  expiresAt DateTime

  @@index([expiresAt])
}

model TenantUser {
  id        String   @id @default(cuid())
  tenantId  String
  userId    String
  roleId    String?
  branchId  String?
  createdAt DateTime @default(now())

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  role   Role?  @relation(fields: [roleId], references: [id], onDelete: SetNull)
  branch Branch? @relation(fields: [branchId], references: [id], onDelete: SetNull)

  @@unique([tenantId, userId])
  @@index([tenantId])
  @@index([userId])
  @@index([branchId])
}

model BranchCategory {
  id        String   @id @default(cuid())
  tenantId  String
  name      String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  tenant   Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  branches Branch[]

  @@unique([tenantId, name])
  @@index([tenantId])
}

model Branch {
  id          String   @id @default(cuid())
  tenantId    String
  categoryId  String?
  code        String?
  name        String
  phone       String?
  address     String?
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  tenant    Tenant          @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  category  BranchCategory? @relation(fields: [categoryId], references: [id], onDelete: SetNull)
  members   TenantUser[]
  shifts    CashierShift[]
  warehouses Warehouse[]
  productPrices ProductPrice[]
  productPriceHistory ProductPriceHistory[]
  productBatches ProductBatch[]

  @@index([tenantId])
  @@index([categoryId])
  @@unique([tenantId, code])
}

model Role {
  id        String   @id @default(cuid())
  tenantId  String?
  name      String
  createdAt DateTime @default(now())

  memberships TenantUser[]
  permissions RolePermission[]
  tenant      Tenant? @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@unique([tenantId, name])
  @@index([tenantId])
}

model Permission {
  id        String   @id @default(cuid())
  tenantId  String?
  key       String
  name      String
  createdAt DateTime @default(now())

  tenant Tenant? @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  roles  RolePermission[]

  @@unique([tenantId, key])
  @@index([tenantId])
}

model RolePermission {
  id           String   @id @default(cuid())
  roleId       String
  permissionId String
  createdAt    DateTime @default(now())

  role       Role       @relation(fields: [roleId], references: [id], onDelete: Cascade)
  permission Permission @relation(fields: [permissionId], references: [id], onDelete: Cascade)

  @@unique([roleId, permissionId])
  @@index([permissionId])
}

model ProductCategory {
  id        String   @id @default(cuid())
  tenantId  String
  name      String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  tenant   Tenant    @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  products Product[]

  @@unique([tenantId, name])
  @@index([tenantId])
}

model ProductBrand {
  id        String   @id @default(cuid())
  tenantId  String
  name      String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  tenant   Tenant    @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  products Product[]

  @@unique([tenantId, name])
  @@index([tenantId])
}

model ProductUnit {
  id        String   @id @default(cuid())
  tenantId  String
  name      String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  tenant   Tenant    @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  products Product[]
  unitOptions ProductUnitOption[]
  conversionsFrom ProductUnitConversion[] @relation("ProductUnitConversionFrom")
  conversionsTo   ProductUnitConversion[] @relation("ProductUnitConversionTo")
  prices   ProductPrice[]
  priceHistory ProductPriceHistory[]

  @@unique([tenantId, name])
  @@index([tenantId])
}

model Product {
  id          String   @id @default(cuid())
  tenantId    String
  sku         String
  name        String
  slug        String?
  description String?
  barcode     String?
  qrCode      String?
  categoryId  String?
  brandId     String?
  supplierId  String?
  unitId      String?
  costPrice    Decimal  @default(0)
  sellingPrice Decimal  @default(0)
  marginPct    Decimal  @default(0)
  taxRate      Decimal  @default(0)
  weight       Decimal  @default(0)
  volume       Decimal  @default(0)
  minStock     Decimal  @default(0)
  reorderPoint Decimal  @default(0)
  isActive    Boolean  @default(true)
  isFeatured  Boolean  @default(false)
  isConsignment Boolean @default(false)
  type        ProductType @default(SINGLE)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  tenant   Tenant            @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  category ProductCategory?  @relation(fields: [categoryId], references: [id], onDelete: SetNull)
  brand    ProductBrand?     @relation(fields: [brandId], references: [id], onDelete: SetNull)
  supplier Supplier?         @relation("SupplierProducts", fields: [supplierId], references: [id], onDelete: SetNull)
  unit     ProductUnit?      @relation(fields: [unitId], references: [id], onDelete: SetNull)
  images   ProductImage[]
  variants ProductVariant[]
  unitOptions ProductUnitOption[]
  conversions ProductUnitConversion[]
  batches  ProductBatch[]
  warehouseStocks ProductWarehouseStock[]
  prices   ProductPrice[]
  priceHistory ProductPriceHistory[]
  costHistory ProductCostHistory[]
  bundles ProductBundle[]
  assemblies ProductAssembly[]
  bundleItems ProductBundleItem[]
  assemblyItems ProductAssemblyItem[]
  serials ProductSerial[]
  suppliers ProductSupplier[]
  transferItems ProductTransferItem[]
  adjustmentItems ProductAdjustmentItem[]
  opnameItems ProductOpnameItem[]
  saleItems SaleItem[]
  purchaseOrderItems PurchaseOrderItem[]

  @@unique([tenantId, sku])
  @@unique([tenantId, qrCode])
  @@unique([tenantId, slug])
  @@index([tenantId])
  @@index([name])
  @@index([barcode])
  @@index([qrCode])
  @@index([categoryId])
  @@index([brandId])
  @@index([supplierId])
  @@index([type])
}

enum ProductType {
  SINGLE
  VARIANT
  BUNDLE
  SERVICE
  DIGITAL
  ASSEMBLY
}

model ProductImage {
  id        String   @id @default(cuid())
  tenantId  String
  productId String
  url       String
  alt       String?
  sortOrder Int      @default(0)
  createdAt DateTime @default(now())

  tenant  Tenant  @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  product Product @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@index([tenantId])
  @@index([productId])
}

model ProductVariant {
  id        String   @id @default(cuid())
  tenantId  String
  productId String
  sku       String
  barcode   String?
  qrCode    String?
  name      String
  attributes Json?
  costPrice Decimal @default(0)
  sellingPrice Decimal @default(0)
  isActive  Boolean @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  tenant  Tenant  @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  product Product @relation(fields: [productId], references: [id], onDelete: Cascade)
  batches ProductBatch[]
  warehouseStocks ProductWarehouseStock[]
  prices  ProductPrice[]
  priceHistory ProductPriceHistory[]
  costHistory ProductCostHistory[]
  serials ProductSerial[]
  bundleItems ProductBundleItem[]
  assemblyItems ProductAssemblyItem[]
  transferItems ProductTransferItem[]
  adjustmentItems ProductAdjustmentItem[]
  opnameItems ProductOpnameItem[]

  @@unique([tenantId, sku])
  @@unique([tenantId, qrCode])
  @@index([tenantId])
  @@index([productId])
  @@index([barcode])
  @@index([qrCode])
}

model ProductUnitOption {
  id        String @id @default(cuid())
  tenantId  String
  productId String
  unitId    String
  isBase    Boolean @default(false)
  isActive  Boolean @default(true)

  tenant  Tenant      @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  product Product     @relation(fields: [productId], references: [id], onDelete: Cascade)
  unit    ProductUnit @relation(fields: [unitId], references: [id], onDelete: Cascade)

  @@unique([tenantId, productId, unitId])
  @@index([tenantId])
  @@index([productId])
  @@index([unitId])
}

model ProductUnitConversion {
  id          String @id @default(cuid())
  tenantId    String
  productId   String
  fromUnitId  String
  toUnitId    String
  multiplier  Decimal @default(1) // fromUnit * multiplier = toUnit
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  tenant   Tenant      @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  product  Product     @relation(fields: [productId], references: [id], onDelete: Cascade)
  fromUnit ProductUnit @relation("ProductUnitConversionFrom", fields: [fromUnitId], references: [id], onDelete: Cascade)
  toUnit   ProductUnit @relation("ProductUnitConversionTo", fields: [toUnitId], references: [id], onDelete: Cascade)

  @@unique([tenantId, productId, fromUnitId, toUnitId])
  @@index([tenantId])
  @@index([productId])
}

enum WarehouseType {
  CENTRAL
  BRANCH
  TRANSIT
}

model Warehouse {
  id        String @id @default(cuid())
  tenantId  String
  branchId  String?
  name      String
  type      WarehouseType @default(BRANCH)
  isActive  Boolean @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  branch Branch? @relation(fields: [branchId], references: [id], onDelete: SetNull)
  stocks ProductWarehouseStock[]
  transfersOut ProductTransfer[] @relation("ProductTransferFrom")
  transfersIn  ProductTransfer[] @relation("ProductTransferTo")
  adjustments  ProductAdjustment[]
  opnames      ProductOpname[]
  batches     ProductBatch[]

  @@unique([tenantId, name])
  @@index([tenantId])
  @@index([branchId])
  @@index([type])
}

model ProductBatch {
  id        String @id @default(cuid())
  tenantId  String
  productId String
  branchId  String?
  warehouseId String?
  variantId String?
  batchNo   String?
  batchNumber String?
  receivedAt DateTime @default(now())
  expiredAt DateTime?
  expiredDate DateTime?
  quantity  Decimal @default(0)
  costPrice Decimal @default(0)
  source    String?
  photoUrl  String?
  ocrText   String?
  confidence Decimal?
  notes     String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  tenant  Tenant  @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  product Product @relation(fields: [productId], references: [id], onDelete: Cascade)
  branch  Branch? @relation(fields: [branchId], references: [id], onDelete: SetNull)
  warehouse Warehouse? @relation(fields: [warehouseId], references: [id], onDelete: SetNull)
  variant ProductVariant? @relation(fields: [variantId], references: [id], onDelete: Cascade)
  stocks  ProductWarehouseStock[]
  transferItems ProductTransferItem[]
  adjustmentItems ProductAdjustmentItem[]
  opnameItems ProductOpnameItem[]

  @@index([tenantId])
  @@index([productId])
  @@index([branchId])
  @@index([warehouseId])
  @@index([variantId])
  @@index([expiredAt])
  @@index([expiredDate])
  @@index([batchNumber])
}

model ProductWarehouseStock {
  id         String @id @default(cuid())
  tenantId   String
  warehouseId String
  productId  String
  variantId  String?
  batchId    String?
  qty        Decimal @default(0)
  updatedAt  DateTime @updatedAt

  tenant    Tenant    @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  warehouse Warehouse @relation(fields: [warehouseId], references: [id], onDelete: Cascade)
  product   Product   @relation(fields: [productId], references: [id], onDelete: Cascade)
  variant   ProductVariant? @relation(fields: [variantId], references: [id], onDelete: Cascade)
  batch     ProductBatch? @relation(fields: [batchId], references: [id], onDelete: SetNull)

  @@unique([tenantId, warehouseId, productId, variantId, batchId])
  @@index([tenantId])
  @@index([warehouseId])
  @@index([productId])
  @@index([variantId])
  @@index([batchId])
}

model ProductPrice {
  id        String @id @default(cuid())
  tenantId  String
  branchId  String?
  productId String
  variantId String?
  unitId    String?
  priceType String @default("RETAIL") // RETAIL|WHOLESALE|MEMBER|RESELLER
  price     Decimal @default(0)
  startsAt  DateTime?
  endsAt    DateTime?
  isActive  Boolean @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  tenant  Tenant  @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  branch  Branch? @relation(fields: [branchId], references: [id], onDelete: SetNull)
  product Product @relation(fields: [productId], references: [id], onDelete: Cascade)
  variant ProductVariant? @relation(fields: [variantId], references: [id], onDelete: Cascade)
  unit    ProductUnit? @relation(fields: [unitId], references: [id], onDelete: SetNull)

  @@index([tenantId])
  @@index([branchId])
  @@index([productId])
  @@index([variantId])
  @@index([priceType])
  @@index([isActive])
}

model ProductPriceHistory {
  id        String @id @default(cuid())
  tenantId  String
  branchId  String?
  productId String
  variantId String?
  unitId    String?
  priceType String
  price     Decimal
  changedAt DateTime @default(now())
  changedById String?

  tenant  Tenant  @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  branch  Branch? @relation(fields: [branchId], references: [id], onDelete: SetNull)
  product Product @relation(fields: [productId], references: [id], onDelete: Cascade)
  variant ProductVariant? @relation(fields: [variantId], references: [id], onDelete: Cascade)
  unit    ProductUnit? @relation(fields: [unitId], references: [id], onDelete: SetNull)
  changedBy User? @relation("ProductPriceHistoryChangedBy", fields: [changedById], references: [id], onDelete: SetNull)

  @@index([tenantId])
  @@index([productId])
  @@index([variantId])
  @@index([branchId])
  @@index([changedAt])
}

model ProductCostHistory {
  id        String @id @default(cuid())
  tenantId  String
  productId String
  variantId String?
  cost      Decimal
  source    String @default("MANUAL") // PURCHASE|MANUAL|IMPORT
  referenceId String?
  createdAt DateTime @default(now())
  createdById String?

  tenant  Tenant  @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  product Product @relation(fields: [productId], references: [id], onDelete: Cascade)
  variant ProductVariant? @relation(fields: [variantId], references: [id], onDelete: Cascade)
  createdBy User? @relation("ProductCostHistoryCreatedBy", fields: [createdById], references: [id], onDelete: SetNull)

  @@index([tenantId])
  @@index([productId])
  @@index([variantId])
  @@index([createdAt])
}

enum ProductSerialStatus {
  AVAILABLE
  SOLD
  RETURNED
}

model ProductSerial {
  id        String @id @default(cuid())
  tenantId  String
  productId String
  variantId String?
  serialNo  String
  status    ProductSerialStatus @default(AVAILABLE)
  warrantyUntil DateTime?
  notes     String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  tenant  Tenant  @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  product Product @relation(fields: [productId], references: [id], onDelete: Cascade)
  variant ProductVariant? @relation(fields: [variantId], references: [id], onDelete: Cascade)

  @@unique([tenantId, serialNo])
  @@index([tenantId])
  @@index([productId])
  @@index([variantId])
  @@index([status])
}

model ProductSupplier {
  id         String @id @default(cuid())
  tenantId   String
  productId  String
  supplierId String
  isPrimary  Boolean @default(false)
  supplierSku String?
  lastCost   Decimal @default(0)
  createdAt  DateTime @default(now())

  tenant   Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  product  Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
  supplier Supplier @relation(fields: [supplierId], references: [id], onDelete: Cascade)

  @@unique([tenantId, productId, supplierId])
  @@index([tenantId])
  @@index([productId])
  @@index([supplierId])
}

model ProductBundle {
  id        String @id @default(cuid())
  tenantId  String
  productId String // the bundle product
  name      String
  isActive  Boolean @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  tenant  Tenant  @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  product Product @relation(fields: [productId], references: [id], onDelete: Cascade)
  items   ProductBundleItem[]

  @@index([tenantId])
  @@index([productId])
}

model ProductBundleItem {
  id        String @id @default(cuid())
  tenantId  String
  bundleId  String
  productId String
  variantId String?
  qty       Decimal @default(1)

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  bundle ProductBundle @relation(fields: [bundleId], references: [id], onDelete: Cascade)
  product Product @relation(fields: [productId], references: [id], onDelete: Cascade)
  variant ProductVariant? @relation(fields: [variantId], references: [id], onDelete: Cascade)

  @@index([tenantId])
  @@index([bundleId])
}

model ProductAssembly {
  id        String @id @default(cuid())
  tenantId  String
  productId String // the assembly output product
  name      String
  isActive  Boolean @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  tenant  Tenant  @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  product Product @relation(fields: [productId], references: [id], onDelete: Cascade)
  items   ProductAssemblyItem[]

  @@index([tenantId])
  @@index([productId])
}

model ProductAssemblyItem {
  id        String @id @default(cuid())
  tenantId  String
  assemblyId String
  productId String
  variantId String?
  qty       Decimal @default(1)

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  assembly ProductAssembly @relation(fields: [assemblyId], references: [id], onDelete: Cascade)
  product Product @relation(fields: [productId], references: [id], onDelete: Cascade)
  variant ProductVariant? @relation(fields: [variantId], references: [id], onDelete: Cascade)

  @@index([tenantId])
  @@index([assemblyId])
}

enum InventoryDocStatus {
  DRAFT
  POSTED
  CANCELED
}

enum StockMoveType {
  ADJUSTMENT
  TRANSFER
  OPNAME
}

model ProductTransfer {
  id          String @id @default(cuid())
  tenantId    String
  fromWarehouseId String
  toWarehouseId   String
  status      InventoryDocStatus @default(DRAFT)
  notes       String?
  createdById String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  fromWarehouse Warehouse @relation("ProductTransferFrom", fields: [fromWarehouseId], references: [id], onDelete: Cascade)
  toWarehouse   Warehouse @relation("ProductTransferTo", fields: [toWarehouseId], references: [id], onDelete: Cascade)
  createdBy User? @relation("ProductTransferCreatedBy", fields: [createdById], references: [id], onDelete: SetNull)
  items  ProductTransferItem[]

  @@index([tenantId])
  @@index([status])
  @@index([fromWarehouseId])
  @@index([toWarehouseId])
}

model ProductTransferItem {
  id         String @id @default(cuid())
  tenantId   String
  transferId String
  productId  String
  variantId  String?
  batchId    String?
  qty        Decimal @default(1)

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  transfer ProductTransfer @relation(fields: [transferId], references: [id], onDelete: Cascade)
  product Product @relation(fields: [productId], references: [id], onDelete: Cascade)
  variant ProductVariant? @relation(fields: [variantId], references: [id], onDelete: Cascade)
  batch   ProductBatch? @relation(fields: [batchId], references: [id], onDelete: SetNull)

  @@index([tenantId])
  @@index([transferId])
}

model ProductAdjustment {
  id          String @id @default(cuid())
  tenantId    String
  warehouseId String
  status      InventoryDocStatus @default(DRAFT)
  reason      String?
  notes       String?
  createdById String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  warehouse Warehouse @relation(fields: [warehouseId], references: [id], onDelete: Cascade)
  createdBy User? @relation("ProductAdjustmentCreatedBy", fields: [createdById], references: [id], onDelete: SetNull)
  items ProductAdjustmentItem[]

  @@index([tenantId])
  @@index([warehouseId])
  @@index([status])
}

model ProductAdjustmentItem {
  id            String @id @default(cuid())
  tenantId      String
  adjustmentId  String
  productId     String
  variantId     String?
  batchId       String?
  qtyDelta      Decimal @default(0)
  notes         String?

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  adjustment ProductAdjustment @relation(fields: [adjustmentId], references: [id], onDelete: Cascade)
  product Product @relation(fields: [productId], references: [id], onDelete: Cascade)
  variant ProductVariant? @relation(fields: [variantId], references: [id], onDelete: Cascade)
  batch   ProductBatch? @relation(fields: [batchId], references: [id], onDelete: SetNull)

  @@index([tenantId])
  @@index([adjustmentId])
}

model ProductOpname {
  id          String @id @default(cuid())
  tenantId    String
  warehouseId String
  status      InventoryDocStatus @default(DRAFT)
  notes       String?
  createdById String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  warehouse Warehouse @relation(fields: [warehouseId], references: [id], onDelete: Cascade)
  createdBy User? @relation("ProductOpnameCreatedBy", fields: [createdById], references: [id], onDelete: SetNull)
  items ProductOpnameItem[]

  @@index([tenantId])
  @@index([warehouseId])
  @@index([status])
}

model ProductOpnameItem {
  id        String @id @default(cuid())
  tenantId  String
  opnameId  String
  productId String
  variantId String?
  batchId   String?
  systemQty Decimal @default(0)
  countedQty Decimal @default(0)
  difference Decimal @default(0)

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  opname ProductOpname @relation(fields: [opnameId], references: [id], onDelete: Cascade)
  product Product @relation(fields: [productId], references: [id], onDelete: Cascade)
  variant ProductVariant? @relation(fields: [variantId], references: [id], onDelete: Cascade)
  batch   ProductBatch? @relation(fields: [batchId], references: [id], onDelete: SetNull)

  @@index([tenantId])
  @@index([opnameId])
}

model Sale {
  id        String   @id @default(cuid())
  tenantId  String
  invoiceNo String
  cashierId String?
  shiftId   String?
  subtotal  Decimal  @default(0)
  tax       Decimal  @default(0)
  discount  Decimal  @default(0)
  total     Decimal  @default(0)
  status    String   @default("PAID")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  shift  CashierShift? @relation(fields: [shiftId], references: [id], onDelete: SetNull)
  items  SaleItem[]
  payments Payment[]

  @@unique([tenantId, invoiceNo])
  @@index([tenantId])
  @@index([createdAt])
  @@index([shiftId])
}

model SaleItem {
  id        String   @id @default(cuid())
  tenantId  String
  saleId    String
  productId String
  name      String
  sku       String
  price     Decimal  @default(0)
  qty       Int      @default(1)
  lineTotal Decimal  @default(0)

  sale    Sale    @relation(fields: [saleId], references: [id], onDelete: Cascade)
  product Product @relation(fields: [productId], references: [id], onDelete: Restrict)

  @@index([tenantId])
  @@index([saleId])
  @@index([productId])
}

model Payment {
  id        String   @id @default(cuid())
  tenantId  String
  saleId    String
  method    String
  amount    Decimal  @default(0)
  reference String?
  createdAt DateTime @default(now())

  sale Sale @relation(fields: [saleId], references: [id], onDelete: Cascade)

  @@index([tenantId])
  @@index([saleId])
}

model AuditLog {
  id        String   @id @default(cuid())
  tenantId  String?
  userId    String?
  action    String
  entity    String
  entityId  String?
  metadata  Json?
  createdAt DateTime @default(now())

  tenant Tenant? @relation(fields: [tenantId], references: [id], onDelete: SetNull)
  user   User?   @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([tenantId])
  @@index([userId])
  @@index([entity])
  @@index([action])
}

model Customer {
  id        String   @id @default(cuid())
  tenantId  String
  name      String
  email     String?
  phone     String?
  address   String?
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([tenantId])
  @@index([name])
  @@index([email])
  @@index([phone])
}

model Supplier {
  id        String   @id @default(cuid())
  tenantId  String
  name      String
  email     String?
  phone     String?
  address   String?
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  purchaseOrders PurchaseOrder[]
  products Product[] @relation("SupplierProducts")
  productLinks ProductSupplier[]

  @@index([tenantId])
  @@index([name])
  @@index([email])
  @@index([phone])
}

model PurchaseOrder {
  id        String         @id @default(cuid())
  tenantId  String
  supplierId String?
  orderNo   String
  status    PurchaseStatus @default(DRAFT)
  notes     String?
  subtotal  Decimal        @default(0)
  tax       Decimal        @default(0)
  total     Decimal        @default(0)
  createdAt DateTime       @default(now())
  updatedAt DateTime       @updatedAt

  tenant   Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  supplier Supplier? @relation(fields: [supplierId], references: [id], onDelete: SetNull)
  items    PurchaseOrderItem[]

  @@unique([tenantId, orderNo])
  @@index([tenantId])
  @@index([createdAt])
  @@index([status])
}

model PurchaseOrderItem {
  id        String   @id @default(cuid())
  tenantId  String
  purchaseOrderId String
  productId String
  name      String
  sku       String
  costPrice Decimal  @default(0)
  qty       Int      @default(1)
  lineTotal Decimal  @default(0)

  purchaseOrder PurchaseOrder @relation(fields: [purchaseOrderId], references: [id], onDelete: Cascade)
  product       Product       @relation(fields: [productId], references: [id], onDelete: Restrict)

  @@index([tenantId])
  @@index([purchaseOrderId])
  @@index([productId])
}

model CashierShift {
  id          String      @id @default(cuid())
  tenantId    String
  branchId    String
  cashierId   String      @map("cashierUserId")

  openedAt        DateTime @default(now())
  closedAt        DateTime?
  openingCash     Decimal  @default(0)
  cashSystem      Decimal  @default(0)
  cashCounted     Decimal?
  cashDifference  Decimal  @default(0)

  totalSales       Decimal @default(0)
  totalCash        Decimal @default(0)
  totalQris        Decimal @default(0)
  totalTransfer    Decimal @default(0)
  totalEwallet     Decimal @default(0)
  transactionCount Int     @default(0)

  status        ShiftStatus @default(OPEN)
  openNote      String?
  closeNote     String?

  approvedById  String?
  approvedAt    DateTime?

  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  tenant     Tenant  @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  branch     Branch  @relation(fields: [branchId], references: [id], onDelete: Restrict)
  cashier    User    @relation("CashierShiftCashier", fields: [cashierId], references: [id], onDelete: Restrict)
  approvedBy User?   @relation("CashierShiftApprovedBy", fields: [approvedById], references: [id], onDelete: SetNull)
  sales      Sale[]

  @@index([tenantId])
  @@index([branchId])
  @@index([cashierId])
  @@index([openedAt])
  @@index([status])
}

// NextAuth / Auth.js models (Prisma Adapter)
model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@index([userId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}
