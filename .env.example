# Database (choose one)
# PostgreSQL:
# DATABASE_URL="postgresql://postgres:postgres@localhost:5432/pos_saas?schema=public"
# Neon (PostgreSQL managed, requires SSL):
# DATABASE_URL="postgresql://USER:PASSWORD@EP-xxxxxx.ap-southeast-1.aws.neon.tech/DBNAME?sslmode=require"
# DIRECT_URL is used only by Prisma migrations/db push. For Neon, use the direct (non-pooled) URL.
# DIRECT_URL="postgresql://USER:PASSWORD@EP-xxxxxx.ap-southeast-1.aws.neon.tech/DBNAME?sslmode=require"
# MySQL:
# DATABASE_URL="mysql://root:password@localhost:3306/pos_saas"

# Auth.js / NextAuth
AUTH_SECRET="replace-with-strong-secret"
AUTH_URL="http://localhost:3000"
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""
# Optional (for UI / client-side checks only)
# NEXT_PUBLIC_GOOGLE_CLIENT_ID=""
# Android Capacitor native Google Sign-In
NEXT_PUBLIC_GOOGLE_WEB_CLIENT_ID=""
NEXT_PUBLIC_GOOGLE_ANDROID_CLIENT_ID=""

# Seed
SEED_PASSWORD="Password123!"

# Email verification (SMTP)
# Gmail example:
# SMTP_HOST="smtp.gmail.com"
# SMTP_PORT="465"
# SMTP_SECURE="true"
# SMTP_USER="your_gmail@gmail.com"
# SMTP_PASS="your_app_password"
SMTP_HOST=""
SMTP_PORT="587"
SMTP_SECURE="false"
SMTP_USER=""
SMTP_PASS=""
EMAIL_FROM="POS Pro <no-reply@yourdomain.com>"
# sync = kirim langsung saat register/resend (recommended for Vercel)
# queue = masuk Redis queue dan wajib memanggil /api/workers/process-queue
EMAIL_VERIFICATION_DELIVERY="sync"

# Redis / Upstash (optional but recommended for Vercel production)
UPSTASH_REDIS_REST_URL=""
UPSTASH_REDIS_REST_TOKEN=""
REDIS_CACHE_TTL_DASHBOARD="60"
REDIS_CACHE_TTL_PRODUCTS="300"
REDIS_CACHE_TTL_SETTINGS="600"
WORKER_SECRET="replace-with-random-worker-secret"

# Prisma query observability (optional)
PRISMA_QUERY_LOG="0"
PRISMA_SLOW_QUERY_MS="250"

# Downloads (optional)
# If you host binaries in `public/downloads`:
# NEXT_PUBLIC_ANDROID_APK_URL="/downloads/pos-pro.apk"
# NEXT_PUBLIC_WINDOWS_EXE_URL="/downloads/pos-pro-setup.exe"
NEXT_PUBLIC_ANDROID_APK_URL=""
NEXT_PUBLIC_WINDOWS_EXE_URL=""

# Android APK wrapper (Capacitor) - hosted renderer URL
CAPACITOR_SERVER_URL="https://pos-next-js-kohl.vercel.app"

# Optional (future)
# MIDTRANS_SERVER_KEY=""
# MIDTRANS_CLIENT_KEY=""
# XENDIT_SECRET_KEY=""
# CLOUDINARY_URL=""
# S3_ENDPOINT=""
# S3_ACCESS_KEY_ID=""
# S3_SECRET_ACCESS_KEY=""
# S3_BUCKET=""

# Redis cache TTL tuning (seconds)
REDIS_CACHE_TTL_PERMISSIONS=300
REDIS_CACHE_TTL_EMAIL_VERIFIED=300
REDIS_CACHE_TTL_TENANT_ACCESS=300
REDIS_CACHE_TTL_TENANT_STATUS=300
REDIS_CACHE_TTL_MEMBERSHIP=300
