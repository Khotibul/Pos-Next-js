# POSQU Pro Desktop Java
APP_NAME=POSQU Pro Desktop
APP_ENV=local

# MySQL local database khusus aplikasi desktop ini.
DB_HOST=localhost
DB_PORT=3306
DB_NAME=posqu_pro_desktop_local
DB_USER=root
DB_PASSWORD=
DB_URL=jdbc:mysql://localhost:3306/posqu_pro_desktop_local?useSSL=false&allowPublicKeyRetrieval=true&serverTimezone=Asia/Jakarta

# Default akun demo setelah seed database dijalankan.
ADMIN_EMAIL=admin@posqu.local
ADMIN_PASSWORD=admin123

# Lisensi lokal tersimpan di tabel licenses pada DB yang sama.
LICENSE_KEY=POSQU-DEMO-2026
LICENSE_COMPANY=POSQU Local Store
LICENSE_DEVICE_ID=LOCAL-DESKTOP

